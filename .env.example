# ─────────────────────────────────────────────────────────────────────────────
# Root environment for docker-compose. Copy to `.env` and fill in real values.
#   cp .env.example .env
# The root `.env` is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=forum
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=forum
# Host port mapped to Postgres 5432
DB_PORT=5843

# ── Backend ─────────────────────────────────────────────────────────────────
# Container listen port + host published port
BACKEND_PORT=3636
# Use a long random string, e.g. `openssl rand -hex 32`
JWT_SECRET=change-this-to-a-long-random-secret
GOOGLE_CLIENT_ID=
# Public URL(s) of the frontend (comma-separated list allowed for CORS)
FRONTEND_URL=http://localhost:8080
# Public URL of this backend (used for locally-stored upload URLs)
BACKEND_URL=http://localhost:3636

# ── File storage ────────────────────────────────────────────────────────────
# 'local' = save to ./uploads | 'cdn' = forward to Axite CDN
STORAGE_DRIVER=local
CDN_BASE_URL=http://axite-elysia:3000
CDN_API_KEY=

# ── SMTP (optional — blank = reset links logged to stdout) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Frontend (build-time args, baked into the static bundle) ─────────────────
# Host port mapped to the frontend nginx (:80)
FRONTEND_PORT=8080
# Must be a URL the BROWSER can reach (not an internal docker hostname)
VITE_API_URL=http://localhost:3636
VITE_GOOGLE_CLIENT_ID=
