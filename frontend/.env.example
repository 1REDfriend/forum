# Frontend build-time env (Vite). Copy to .env for local dev:
#   cp .env.example .env
# These values are baked into the static bundle at build time and are public.

# URL the browser uses to reach the backend API
VITE_API_URL=http://localhost:3636

# Google OAuth client ID (public)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
