JWT_SECRET=your-jwt_secret
GOOGLE_CLIENT_ID=your-google_client_id
# Public absolute URL of the frontend. Used to build absolute OG image/link URLs — must match frontend VITE_SITE_URL.
FRONTEND_URL=your-frontend_url
BACKEND_URL=your-backend_url
STORAGE_DRIVER=your-storage_driver
CDN_BASE_URL=your-cdn_base_url
CDN_API_KEY=your-cdn_api_key
VITE_API_URL=your-vite_api_url
VITE_GOOGLE_CLIENT_ID=your-vite_google_client_id

DATABASE_URL=your-database_url

# ── docker-compose infra (added) ──
POSTGRES_USER=your-postgres_user
POSTGRES_PASSWORD=your-postgres_password
POSTGRES_DB=your-postgres_db
DB_PORT=your-db_port
BACKEND_PORT=your-backend_port
FRONTEND_PORT=your-frontend_port
SMTP_HOST=your-smtp_host
SMTP_PORT=your-smtp_port
SMTP_SECURE=your-smtp_secure
